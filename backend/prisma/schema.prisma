// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String               @id @default(cuid())
  name                  String
  image                 String?
  email                 String?              @unique
  isPremium             Boolean              @default(false)
  role                  Role                 @default(USER)
  activeRefreshFamilyId String?              @map("active_refresh_family_id")
  accounts              Account[]
  refreshTokens         RefreshToken[]
  agreements            UserAgreement[]
  agreementEvents       UserAgreementEvent[]
  people                Person[]
  businessCards         BusinessCard[]
  extraContacts         ExtraContact[]
  records               Record[]
  mediaFiles            MediaFile[]
  schedules             Schedule[]
  pushTokens            PushToken[]
  notificationJobs      NotificationJob[]
  schedulePeople        SchedulePerson[]
  recordPeople          RecordPerson[]
  recordKeywords        RecordKeyword[]
  companies             Company[]
  recordMemos           RecordMemo[]
  positions             Position[]
  relationships         Relationship[]
  jobs                  Job[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model AgreementDocument {
  id          String               @id @default(cuid())
  type        AgreementType
  version     String
  title       String
  content     String
  contentHash String               @map("content_hash")
  required    Boolean              @default(false)
  effectiveAt DateTime             @map("effective_at")
  retiredAt   DateTime?            @map("retired_at")
  agreements  UserAgreement[]
  events      UserAgreementEvent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([type, version])
  @@index([type, effectiveAt])
  @@map("agreement_documents")
}

enum AgreementType {
  TERMS
  PRIVACY_REQUIRED
  MARKETING_EMAIL
  MARKETING_SMS
}

model UserAgreement {
  id          String               @id @default(cuid())
  userId      String               @map("user_id")
  documentId  String               @map("document_id")
  agreedAt    DateTime             @map("agreed_at")
  withdrawnAt DateTime?            @map("withdrawn_at")
  events      UserAgreementEvent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  document AgreementDocument @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@unique([userId, documentId])
  @@index([documentId, withdrawnAt])
  @@map("user_agreements")
}

model UserAgreementEvent {
  id          String          @id @default(cuid())
  userId      String          @map("user_id")
  agreementId String?         @map("agreement_id")
  documentId  String          @map("document_id")
  action      AgreementAction
  occurredAt  DateTime        @default(now()) @map("occurred_at")
  ipAddress   String?         @map("ip_address")
  userAgent   String?         @map("user_agent")

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  agreement UserAgreement?    @relation(fields: [agreementId], references: [id], onDelete: SetNull)
  document  AgreementDocument @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@index([userId, occurredAt])
  @@index([documentId, action, occurredAt])
  @@index([agreementId])
  @@map("user_agreement_events")
}

enum AgreementAction {
  AGREED
  WITHDRAWN
}

model Account {
  userId            String @map("user_id")
  provider          String
  providerAccountId String @map("provider_account_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model RefreshToken {
  id        String @id @default(cuid())
  userId    String @map("user_id")
  tokenHash String @unique @map("token_hash")
  familyId  String @map("family_id")

  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([userId, familyId])
  @@map("refresh_tokens")
}

model Person {
  id                             String            @id @default(cuid())
  userId                         String            @map("user_id")
  name                           String
  profileImageFileId             String?           @unique @map("profile_image_file_id")
  birthDate                      DateTime?         @map("birth_date") @db.Date
  isImportant                    Boolean           @default(false) @map("is_important")
  phoneNumber                    String            @map("phone_number")
  job                            String?
  company                        String?
  position                       String?
  relationship                   String?
  personality                    String?
  birthdayNotificationEnabled    Boolean           @default(false) @map("birthday_notification_enabled")
  birthdayNotificationOffsetDays Int               @default(1) @map("birthday_notification_offset_days")
  interactedAt                   DateTime          @default(now()) @map("interacted_at")
  businessCards                  BusinessCard[]
  extraContacts                  ExtraContact[]
  schedules                      SchedulePerson[]
  records                        RecordPerson[]
  notificationJobs               NotificationJob[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileImageFile MediaFile? @relation("PersonProfileImage", fields: [profileImageFileId], references: [id], onDelete: SetNull)

  @@unique([id, userId])
  @@index([userId])
  @@index([userId, isImportant, interactedAt])
  @@map("people")
}

model Job {
  id     String @id @default(cuid())
  userId String @map("user_id")
  name   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("jobs")
}

model Company {
  id     String @id @default(cuid())
  userId String @map("user_id")
  name   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("companies")
}

model Position {
  id     String @id @default(cuid())
  userId String @map("user_id")
  name   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("positions")
}

model Relationship {
  id     String @id @default(cuid())
  userId String @map("user_id")
  name   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("relationships")
}

model BusinessCard {
  id               String  @id @default(cuid())
  userId           String  @map("user_id")
  personId         String  @map("person_id")
  frontImageFileId String? @unique @map("front_image_file_id")
  backImageFileId  String? @unique @map("back_image_file_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  person         Person     @relation(fields: [personId, userId], references: [id, userId], onDelete: Cascade)
  frontImageFile MediaFile? @relation("BusinessCardFrontImage", fields: [frontImageFileId], references: [id], onDelete: SetNull)
  backImageFile  MediaFile? @relation("BusinessCardBackImage", fields: [backImageFileId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([personId])
  @@map("business_cards")
}

model MediaFile {
  id           String         @id @default(cuid())
  userId       String         @map("user_id")
  type         MediaFileType
  usage        MediaFileUsage
  bucket       String
  s3Key        String         @unique @map("s3_key")
  contentType  String         @map("content_type")
  sizeBytes    Int            @map("size_bytes")
  originalName String?        @map("original_name")
  deletedAt    DateTime?      @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  personProfile     Person?       @relation("PersonProfileImage")
  businessCardFront BusinessCard? @relation("BusinessCardFrontImage")
  businessCardBack  BusinessCard? @relation("BusinessCardBackImage")
  recordVoice       Record?       @relation("RecordVoiceFile")

  @@index([userId])
  @@index([userId, usage])
  @@map("media_files")
}

enum MediaFileType {
  IMAGE
  AUDIO
}

enum MediaFileUsage {
  PERSON_PROFILE
  BUSINESS_CARD_FRONT
  BUSINESS_CARD_BACK
  RECORD_VOICE
}

model ExtraContact {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  personId String @map("person_id")
  type     String
  content  String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId, userId], references: [id, userId], onDelete: Cascade)

  @@index([userId])
  @@index([personId])
  @@map("extra_contacts")
}

model Schedule {
  id                  String            @id @default(cuid())
  userId              String            @map("user_id")
  title               String            @default("제목 없음")
  content             String?
  scheduleTime        DateTime          @map("schedule_time")
  reminderOffsetDays  Int               @default(0) @map("reminder_offset_days")
  notificationEnabled Boolean           @default(false) @map("notification_enabled")
  people              SchedulePerson[]
  notificationJobs    NotificationJob[]
  record              Record?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([id, userId])
  @@index([userId])
  @@index([userId, scheduleTime])
  @@map("schedules")
}

model SchedulePerson {
  userId     String @map("user_id")
  scheduleId String @map("schedule_id")
  personId   String @map("person_id")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule Schedule @relation(fields: [scheduleId, userId], references: [id, userId], onDelete: Cascade)
  person   Person   @relation(fields: [personId, userId], references: [id, userId], onDelete: Cascade)

  @@id([scheduleId, personId])
  @@index([userId])
  @@index([personId])
  @@map("schedule_people")
}

model PushToken {
  id         String        @id @default(cuid())
  userId     String        @map("user_id")
  token      String        @unique
  platform   PushPlatform?
  revokedAt  DateTime?     @map("revoked_at")
  lastSeenAt DateTime?     @map("last_seen_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

enum PushPlatform {
  IOS
  ANDROID
  WEB
}

model NotificationJob {
  id           String             @id @default(cuid())
  userId       String             @map("user_id")
  type         NotificationType
  status       NotificationStatus @default(PENDING)
  scheduleId   String?            @map("schedule_id")
  personId     String?            @map("person_id")
  scheduledAt  DateTime           @map("scheduled_at")
  dedupeKey    String             @map("dedupe_key")
  attemptCount Int                @default(0) @map("attempt_count")

  sentAt        DateTime? @map("sent_at")
  failedAt      DateTime? @map("failed_at")
  lastAttemptAt DateTime? @map("last_attempt_at")
  errorCode     String?   @map("error_code")
  errorMessage  String?   @map("error_message")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule Schedule? @relation(fields: [scheduleId, userId], references: [id, userId], onDelete: Cascade)
  person   Person?   @relation(fields: [personId, userId], references: [id, userId], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([status, scheduledAt])
  @@index([scheduleId])
  @@index([personId])
  @@map("notification_jobs")
}

enum NotificationType {
  SCHEDULE
  BIRTHDAY
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

model Record {
  id                   String          @id @default(cuid())
  userId               String          @map("user_id")
  type                 RecordType      @default(TEXT)
  title                String          @default("제목 없음")
  content              String?
  voiceFileId          String?         @unique @map("voice_file_id")
  scheduleId           String?         @unique @map("schedule_id")
  voiceDurationSeconds Int?            @map("voice_duration_seconds")
  people               RecordPerson[]
  keywords             RecordKeyword[]
  recordMemo           RecordMemo?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceFile MediaFile? @relation("RecordVoiceFile", fields: [voiceFileId], references: [id], onDelete: SetNull)
  schedule  Schedule?  @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  @@unique([id, userId])
  @@index([userId])
  @@index([userId, createdAt])
  @@map("records")
}

enum RecordType {
  TEXT
  VOICE
}

model RecordPerson {
  userId   String @map("user_id")
  recordId String @map("record_id")
  personId String @map("person_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  record Record @relation(fields: [recordId, userId], references: [id, userId], onDelete: Cascade)
  person Person @relation(fields: [personId, userId], references: [id, userId], onDelete: Cascade)

  @@id([recordId, personId])
  @@index([userId])
  @@index([personId])
  @@map("record_people")
}

model RecordKeyword {
  userId   String @map("user_id")
  recordId String @map("record_id")
  name     String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  record Record @relation(fields: [recordId, userId], references: [id, userId], onDelete: Cascade)

  @@id([recordId, name])
  @@index([userId])
  @@index([userId, name])
  @@map("record_keywords")
}

model RecordMemo {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  recordId String @map("record_id")
  content  String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  record Record @relation(fields: [recordId, userId], references: [id, userId], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([recordId, userId])
  @@index([userId])
  @@index([recordId])
  @@map("record_memos")
}
