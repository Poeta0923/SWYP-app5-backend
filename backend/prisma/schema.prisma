// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String            @id @default(cuid())
  name                  String
  image                 String?
  email                 String?           @unique
  isPremium             Boolean           @default(false)
  role                  Role              @default(USER)
  activeRefreshFamilyId String?           @map("active_refresh_family_id")
  accounts              Account[]
  refreshTokens         RefreshToken[]
  people                Person[]
  businessCards         BusinessCard[]
  extraContacts         ExtraContact[]
  records               Record[]
  schedules             Schedule[]
  pushTokens            PushToken[]
  notificationJobs      NotificationJob[]
  schedulePeople        SchedulePerson[]
  recordPeople          RecordPerson[]
  recordKeywords        RecordKeyword[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

model Account {
  userId            String @map("user_id")
  provider          String
  providerAccountId String @map("provider_account_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model RefreshToken {
  id        String @id @default(cuid())
  userId    String @map("user_id")
  tokenHash String @unique @map("token_hash")
  familyId  String @map("family_id")

  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([userId, familyId])
  @@map("refresh_tokens")
}

model Person {
  id                          String            @id @default(cuid())
  userId                      String            @map("user_id")
  name                        String
  image                       String?
  birthDate                   DateTime?         @map("birth_date") @db.Date
  isImportant                 Boolean           @default(false) @map("is_important")
  phoneNumber                 String?           @map("phone_number")
  job                         String?
  company                     String?
  relationship                String?
  personality                 String?
  birthdayNotificationEnabled Boolean           @default(false) @map("birthday_notification_enabled")
  scheduleNotificationEnabled Boolean           @default(false) @map("schedule_notification_enabled")
  businessCards               BusinessCard[]
  extraContacts               ExtraContact[]
  schedules                   SchedulePerson[]
  records                     RecordPerson[]
  notificationJobs            NotificationJob[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([id, userId])
  @@index([userId])
  @@map("people")
}

model BusinessCard {
  id       String  @id @default(cuid())
  userId   String  @map("user_id")
  personId String  @map("person_id")
  image    String?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId, userId], references: [id, userId], onDelete: Cascade)

  @@index([userId])
  @@index([personId])
  @@map("business_cards")
}

model ExtraContact {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  personId String @map("person_id")
  type     String
  content  String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId, userId], references: [id, userId], onDelete: Cascade)

  @@index([userId])
  @@index([personId])
  @@map("extra_contacts")
}

model Schedule {
  id                  String            @id @default(cuid())
  userId              String            @map("user_id")
  title               String            @default("제목 없음")
  content             String?
  scheduleTime        DateTime?         @map("schedule_time")
  reminderTime        DateTime?         @map("reminder_time")
  notificationEnabled Boolean           @default(false) @map("notification_enabled")
  people              SchedulePerson[]
  notificationJobs    NotificationJob[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([id, userId])
  @@index([userId])
  @@map("schedules")
}

model PushToken {
  id         String        @id @default(cuid())
  userId     String        @map("user_id")
  token      String        @unique
  platform   PushPlatform?
  revokedAt  DateTime?     @map("revoked_at")
  lastSeenAt DateTime?     @map("last_seen_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

enum PushPlatform {
  IOS
  ANDROID
  WEB
}

model NotificationJob {
  id           String             @id @default(cuid())
  userId       String             @map("user_id")
  type         NotificationType
  status       NotificationStatus @default(PENDING)
  scheduleId   String?            @map("schedule_id")
  personId     String?            @map("person_id")
  scheduledAt  DateTime           @map("scheduled_at")
  dedupeKey    String             @map("dedupe_key")
  attemptCount Int                @default(0) @map("attempt_count")

  sentAt        DateTime? @map("sent_at")
  failedAt      DateTime? @map("failed_at")
  lastAttemptAt DateTime? @map("last_attempt_at")
  errorCode     String?   @map("error_code")
  errorMessage  String?   @map("error_message")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule Schedule? @relation(fields: [scheduleId, userId], references: [id, userId], onDelete: Cascade)
  person   Person?   @relation(fields: [personId, userId], references: [id, userId], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([status, scheduledAt])
  @@index([scheduleId])
  @@index([personId])
  @@map("notification_jobs")
}

enum NotificationType {
  SCHEDULE
  BIRTHDAY
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

model Record {
  id        String          @id @default(cuid())
  userId    String          @map("user_id")
  type      RecordType      @default(TEXT)
  title     String          @default("제목 없음")
  content   String?
  voiceFile String?         @map("voice_file")
  people    RecordPerson[]
  keywords  RecordKeyword[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([id, userId])
  @@index([userId])
  @@map("records")
}

enum RecordType {
  TEXT
  VOICE
}

model SchedulePerson {
  userId     String @map("user_id")
  scheduleId String @map("schedule_id")
  personId   String @map("person_id")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule Schedule @relation(fields: [scheduleId, userId], references: [id, userId], onDelete: Cascade)
  person   Person   @relation(fields: [personId, userId], references: [id, userId], onDelete: Cascade)

  @@id([scheduleId, personId])
  @@index([userId])
  @@index([personId])
  @@map("schedule_people")
}

model RecordPerson {
  userId   String @map("user_id")
  recordId String @map("record_id")
  personId String @map("person_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  record Record @relation(fields: [recordId, userId], references: [id, userId], onDelete: Cascade)
  person Person @relation(fields: [personId, userId], references: [id, userId], onDelete: Cascade)

  @@id([recordId, personId])
  @@index([userId])
  @@index([personId])
  @@map("record_people")
}

model RecordKeyword {
  userId   String @map("user_id")
  recordId String @map("record_id")
  name     String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  record Record @relation(fields: [recordId, userId], references: [id, userId], onDelete: Cascade)

  @@id([recordId, name])
  @@index([userId])
  @@index([userId, name])
  @@map("record_keywords")
}
