// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                    String               @id @default(cuid())
  name                  String
  image                 String?
  email                 String?
  emailHash             String?              @unique @map("email_hash")
  plan                  UserPlan             @default(Basic)
  role                  Role                 @default(USER)
  activeRefreshFamilyId String?              @map("active_refresh_family_id")
  accounts              Account[]
  refreshTokens         RefreshToken[]
  agreements            UserAgreement[]
  agreementEvents       UserAgreementEvent[]
  people                Person[]
  businessCards         BusinessCard[]
  extraContacts         ExtraContact[]
  records               Record[]
  mediaFiles            MediaFile[]
  schedules             Schedule[]
  pushTokens            PushToken[]
  notificationJobs      NotificationJob[]
  notifications         Notification[]
  schedulePeople        SchedulePerson[]
  recordPeople          RecordPerson[]
  recordKeywords        RecordKeyword[]
  companies             Company[]
  recordMemos           RecordMemo[]
  positions             Position[]
  relationships         Relationship[]
  jobs                  Job[]
  voiceSttJobs          VoiceSttJob[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("users")
}

enum Role {
  USER
  ADMIN
}

enum UserPlan {
  Basic
  Pro
  Premium
}

/// 요금제 카탈로그. code(UserPlan)로 User.plan과 연결된다.
/// 인물 수/용량/청구액만 정형 컬럼으로 저장하고, 화자분리 같은 부가 혜택 문구는
/// 표시용이라 DB에 두지 않고 서비스에서 응답 시 붙인다.
model Plan {
  code           UserPlan @id
  maxPeople      Int?     @map("max_people") // NULL = 무제한
  storageLimitMb Int      @map("storage_limit_mb") // 클라우드 용량, MB 단위
  priceMonthly   Int      @map("price_monthly") // 월 청구액, 원 단위 (0 = 무료)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("plans")
}

model AgreementDocument {
  id          String               @id @default(cuid())
  type        AgreementType
  version     String
  title       String
  content     String
  contentHash String               @map("content_hash")
  required    Boolean              @default(false)
  effectiveAt DateTime             @map("effective_at")
  retiredAt   DateTime?            @map("retired_at")
  agreements  UserAgreement[]
  events      UserAgreementEvent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([type, version])
  @@index([type, effectiveAt])
  @@map("agreement_documents")
}

enum AgreementType {
  AGE_CONFIRMATION
  TERMS_OF_SERVICE
  PRIVACY_COLLECTION_AND_PROCESSING_CONSENT
  THIRD_PARTY_INFORMATION_PROVISION_CONSENT
  MARKETING_AND_PUSH_NOTIFICATION_CONSENT
}

model UserAgreement {
  id          String               @id @default(cuid())
  userId      String               @map("user_id")
  documentId  String               @map("document_id")
  agreedAt    DateTime             @map("agreed_at")
  withdrawnAt DateTime?            @map("withdrawn_at")
  events      UserAgreementEvent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  document AgreementDocument @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@unique([userId, documentId])
  @@index([documentId, withdrawnAt])
  @@map("user_agreements")
}

model UserAgreementEvent {
  id          String          @id @default(cuid())
  userId      String          @map("user_id")
  agreementId String?         @map("agreement_id")
  documentId  String          @map("document_id")
  action      AgreementAction
  occurredAt  DateTime        @default(now()) @map("occurred_at")
  ipAddress   String?         @map("ip_address")
  userAgent   String?         @map("user_agent")

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  agreement UserAgreement?    @relation(fields: [agreementId], references: [id], onDelete: SetNull)
  document  AgreementDocument @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@index([userId, occurredAt])
  @@index([documentId, action, occurredAt])
  @@index([agreementId])
  @@map("user_agreement_events")
}

enum AgreementAction {
  AGREED
  WITHDRAWN
}

model Account {
  userId            String @map("user_id")
  provider          String
  providerAccountId String @map("provider_account_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model RefreshToken {
  id        String @id @default(cuid())
  userId    String @map("user_id")
  tokenHash String @unique @map("token_hash")
  familyId  String @map("family_id")

  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([userId, familyId])
  @@map("refresh_tokens")
}

model Person {
  id                                String            @id @default(cuid())
  userId                            String            @map("user_id")
  name                              String
  profileImageFileId                String?           @unique @map("profile_image_file_id")
  birthDate                         String?           @map("birth_date")
  birthMonth                        Int?              @map("birth_month")
  birthDay                          Int?              @map("birth_day")
  isImportant                       Boolean           @default(false) @map("is_important")
  phoneNumber                       String            @map("phone_number")
  phoneNumberHash                   String?           @map("phone_number_hash")
  job                               String?
  company                           String?
  position                          String?
  relationship                      String?
  personality                       String?
  birthdayNotificationEnabled       Boolean           @default(false) @map("birthday_notification_enabled")
  birthdayNotificationOffsetMinutes Int               @default(1440) @map("birthday_notification_offset_minutes")
  interactedAt                      DateTime          @default(now()) @map("interacted_at")
  businessCards                     BusinessCard[]
  extraContacts                     ExtraContact[]
  schedules                         SchedulePerson[]
  records                           RecordPerson[]
  notificationJobs                  NotificationJob[]
  notifications                     Notification[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  profileImageFile MediaFile? @relation("PersonProfileImage", fields: [profileImageFileId], references: [id], onDelete: SetNull)

  @@unique([id, userId])
  @@index([userId])
  @@index([userId, phoneNumberHash])
  @@index([userId, isImportant, interactedAt])
  @@map("people")
}

model Job {
  id     String @id @default(cuid())
  userId String @map("user_id")
  name   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("jobs")
}

model Company {
  id     String @id @default(cuid())
  userId String @map("user_id")
  name   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("companies")
}

model Position {
  id     String @id @default(cuid())
  userId String @map("user_id")
  name   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("positions")
}

model Relationship {
  id     String @id @default(cuid())
  userId String @map("user_id")
  name   String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
  @@index([userId])
  @@map("relationships")
}

model BusinessCard {
  id               String  @id @default(cuid())
  userId           String  @map("user_id")
  personId         String  @map("person_id")
  frontImageFileId String? @unique @map("front_image_file_id")
  backImageFileId  String? @unique @map("back_image_file_id")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user           User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  person         Person     @relation(fields: [personId, userId], references: [id, userId], onDelete: Cascade)
  frontImageFile MediaFile? @relation("BusinessCardFrontImage", fields: [frontImageFileId], references: [id], onDelete: SetNull)
  backImageFile  MediaFile? @relation("BusinessCardBackImage", fields: [backImageFileId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([personId])
  @@map("business_cards")
}

model MediaFile {
  id           String         @id @default(cuid())
  userId       String         @map("user_id")
  type         MediaFileType
  usage        MediaFileUsage
  bucket       String
  s3Key        String         @unique @map("s3_key")
  contentType  String         @map("content_type")
  sizeBytes    Int            @map("size_bytes")
  originalName String?        @map("original_name")
  deletedAt    DateTime?      @map("deleted_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user              User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  personProfile     Person?       @relation("PersonProfileImage")
  businessCardFront BusinessCard? @relation("BusinessCardFrontImage")
  businessCardBack  BusinessCard? @relation("BusinessCardBackImage")
  recordVoice       Record?       @relation("RecordVoiceFile")
  sttJob            VoiceSttJob?

  @@index([userId])
  @@index([userId, usage])
  @@map("media_files")
}

enum MediaFileType {
  IMAGE
  AUDIO
}

enum MediaFileUsage {
  PERSON_PROFILE
  BUSINESS_CARD_FRONT
  BUSINESS_CARD_BACK
  RECORD_VOICE
}

model ExtraContact {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  personId String @map("person_id")
  type     String
  content  String

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId, userId], references: [id, userId], onDelete: Cascade)

  @@index([userId])
  @@index([personId])
  @@map("extra_contacts")
}

model Schedule {
  id                    String            @id @default(cuid())
  userId                String            @map("user_id")
  title                 String            @default("제목 없음")
  content               String?
  scheduleTime          DateTime          @map("schedule_time")
  bookMark              Boolean           @default(false) @map("book_mark")
  reminderOffsetMinutes Int               @default(0) @map("reminder_offset_minutes")
  notificationEnabled   Boolean           @default(false) @map("notification_enabled")
  people                SchedulePerson[]
  notificationJobs      NotificationJob[]
  notifications         Notification[]
  record                Record?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([id, userId])
  @@index([userId])
  @@index([userId, scheduleTime])
  @@map("schedules")
}

model SchedulePerson {
  userId     String @map("user_id")
  scheduleId String @map("schedule_id")
  personId   String @map("person_id")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule Schedule @relation(fields: [scheduleId, userId], references: [id, userId], onDelete: Cascade)
  person   Person   @relation(fields: [personId, userId], references: [id, userId], onDelete: Cascade)

  @@id([scheduleId, personId])
  @@index([userId])
  @@index([personId])
  @@map("schedule_people")
}

model PushToken {
  id         String        @id @default(cuid())
  userId     String        @map("user_id")
  token      String        @unique
  platform   PushPlatform?
  revokedAt  DateTime?     @map("revoked_at")
  lastSeenAt DateTime?     @map("last_seen_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_tokens")
}

enum PushPlatform {
  IOS
  ANDROID
  WEB
}

model NotificationJob {
  id           String             @id @default(cuid())
  userId       String             @map("user_id")
  type         NotificationType
  status       NotificationStatus @default(PENDING)
  scheduleId   String?            @map("schedule_id")
  personId     String?            @map("person_id")
  scheduledAt  DateTime           @map("scheduled_at")
  dedupeKey    String             @map("dedupe_key")
  attemptCount Int                @default(0) @map("attempt_count")

  sentAt        DateTime? @map("sent_at")
  failedAt      DateTime? @map("failed_at")
  lastAttemptAt DateTime? @map("last_attempt_at")
  errorCode     String?   @map("error_code")
  errorMessage  String?   @map("error_message")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule Schedule? @relation(fields: [scheduleId, userId], references: [id, userId], onDelete: Cascade)
  person   Person?   @relation(fields: [personId, userId], references: [id, userId], onDelete: Cascade)

  @@unique([userId, dedupeKey])
  @@index([status, scheduledAt])
  @@index([scheduleId])
  @@index([personId])
  @@map("notification_jobs")
}

model Notification {
  id                String           @id @default(cuid())
  userId            String           @map("user_id")
  type              NotificationType
  title             String
  body              String
  data              Json?
  notificationJobId String?          @map("notification_job_id")
  scheduleId        String?          @map("schedule_id")
  personId          String?          @map("person_id")
  sentAt            DateTime         @default(now()) @map("sent_at")
  readAt            DateTime?        @map("read_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  schedule Schedule? @relation(fields: [scheduleId], references: [id], onDelete: SetNull)
  person   Person?   @relation(fields: [personId], references: [id], onDelete: SetNull)

  @@index([userId, sentAt])
  @@index([userId, readAt])
  @@index([notificationJobId])
  @@index([scheduleId])
  @@index([personId])
  @@map("notifications")
}

enum NotificationType {
  SCHEDULE
  BIRTHDAY
}

enum NotificationStatus {
  PENDING
  SENT
  FAILED
  CANCELED
}

model Record {
  id                   String          @id @default(cuid())
  userId               String          @map("user_id")
  type                 RecordType      @default(TEXT)
  title                String          @default("제목 없음")
  content              String?
  bookMark             Boolean         @default(false) @map("book_mark")
  voiceFileId          String?         @unique @map("voice_file_id")
  scheduleId           String?         @unique @map("schedule_id")
  voiceDurationSeconds Int?            @map("voice_duration_seconds")
  people               RecordPerson[]
  keywords             RecordKeyword[]
  recordMemo           RecordMemo?
  sttJob               VoiceSttJob?

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceFile MediaFile? @relation("RecordVoiceFile", fields: [voiceFileId], references: [id], onDelete: SetNull)
  schedule  Schedule?  @relation(fields: [scheduleId], references: [id], onDelete: SetNull)

  @@unique([id, userId])
  @@index([userId])
  @@index([userId, createdAt])
  @@map("records")
}

enum RecordType {
  TEXT
  VOICE
}

/// 음성 기록 STT/요약 비동기 처리 잡. 업로드 요청은 즉시 잡을 만들고 반환하며,
/// 백그라운드에서 STT → 요약을 처리한 뒤 완료 시점에만 Record를 생성한다.
/// 클라이언트는 status를 폴링하고, COMPLETED 시 recordId로 상세를 조회한다.
model VoiceSttJob {
  id           String            @id @default(cuid())
  userId       String            @map("user_id")
  status       VoiceSttJobStatus @default(STT_PROCESSING)
  voiceFileId  String            @unique @map("voice_file_id")
  recordId     String?           @map("record_id")
  // 완료 시점에 RecordMemo로 옮기기 전까지 PII 암호화 상태로 보관한다.
  recordMemo   String?           @map("record_memo")
  errorCode    String?           @map("error_code")
  errorMessage String?           @map("error_message")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  voiceFile MediaFile @relation(fields: [voiceFileId], references: [id], onDelete: Cascade)
  record    Record?   @relation(fields: [recordId, userId], references: [id, userId], onDelete: Cascade)

  @@unique([recordId, userId])
  @@index([userId])
  @@index([status])
  @@map("voice_stt_jobs")
}

enum VoiceSttJobStatus {
  STT_PROCESSING
  SUMMARY_PROCESSING
  COMPLETED
  FAILED
}

model RecordPerson {
  userId   String @map("user_id")
  recordId String @map("record_id")
  personId String @map("person_id")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  record Record @relation(fields: [recordId, userId], references: [id, userId], onDelete: Cascade)
  person Person @relation(fields: [personId, userId], references: [id, userId], onDelete: Cascade)

  @@id([recordId, personId])
  @@index([userId])
  @@index([personId])
  @@map("record_people")
}

model RecordKeyword {
  userId   String @map("user_id")
  recordId String @map("record_id")
  name     String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  record Record @relation(fields: [recordId, userId], references: [id, userId], onDelete: Cascade)

  @@id([recordId, name])
  @@index([userId])
  @@index([userId, name])
  @@map("record_keywords")
}

model RecordMemo {
  id       String @id @default(cuid())
  userId   String @map("user_id")
  recordId String @map("record_id")
  content  String

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  record Record @relation(fields: [recordId, userId], references: [id, userId], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([recordId, userId])
  @@index([userId])
  @@index([recordId])
  @@map("record_memos")
}
